<html>
  <head>
    <meta charset="UTF-8" />
    <style>
      body {
        font-family: Arial;
        padding: 40px;
      }

      h1 {
        margin-bottom: 5px;
      }
      h2 {
        margin-top: 30px;
      }

      ul {
        padding-left: 20px;
      }
    </style>
  </head>

  <body>

    <h1>{{name}}</h1>
    <p>{{title}}</p>

    <h2>Skills</h2>
    <ul>
      {{#each skills}}
        <li>{{this}}</li>
      {{/each}}
    </ul>

    <h2>Experience</h2>

    {{#each experience}}
      <div>
        <strong>{{title}}</strong>
        —
        {{company}}
        ({{years}})
        <ul>
          {{#each bullets}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/each}}

  </body>
</html>